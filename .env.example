# Copy to .env and fill in. NEVER commit the real .env.

# Supabase Postgres (Project Settings -> Database -> Connection string)
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# API
API_PORT=4000

# Redis (BullMQ) - local docker or VPS
REDIS_URL=redis://localhost:6379

# Scrapers
OVERPASS_URL=https://overpass-api.de/api/interpreter
SCRAPER_USER_AGENT=bizfinder-ie/0.1 (contact: you@example.com)

# Dev convenience: restrict scraping to one county while developing
DEV_COUNTY=Galway

# CRO Open Services — free company-search API (register at services.cro.ie)
CRO_API_EMAIL=
CRO_API_KEY=

# Stripe (test mode for dev). pk_* = browser-safe, sk_* = server-only secret.
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
