# Copy to .env and fill in. NEVER commit the real .env.

# Supabase Postgres (Project Settings -> Database -> Connection string)
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# API
API_PORT=4000

# Redis (BullMQ) - local docker or VPS
REDIS_URL=redis://localhost:6379

# Scrapers
OVERPASS_URL=https://overpass-api.de/api/interpreter
SCRAPER_USER_AGENT=bizfinder-ie/0.1 (contact: you@example.com)

# Dev convenience: restrict scraping to one county while developing
DEV_COUNTY=Galway
